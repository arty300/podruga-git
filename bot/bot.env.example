TELEGRAM_BOT_TOKEN=123456:telegram-token
RUNPOD_API_KEY=runpod-api-key
RUNPOD_ENDPOINT_ID=runpod-endpoint-id

# Optional: comma-separated Telegram chat IDs allowed to use this bot.
# Leave empty while testing if the bot is private.
TELEGRAM_ALLOWED_CHAT_IDS=

# Optional tuning.
BOT_MAX_WORKERS=2
REQUEST_TIMEOUT=60
RUNPOD_POLL_INTERVAL=3
RUNPOD_JOB_TIMEOUT=900
RUNPOD_EXECUTION_TIMEOUT_MS=900000
RUNPOD_TTL_MS=1800000
LOG_LEVEL=INFO

# Optional prompt rewriting before sending to RunPod.
# When enabled, the bot rewrites human text into a comma-separated ComfyUI positive prompt.
PROMPT_REWRITE_ENABLED=0
PROMPT_REWRITE_API_KEY=
PROMPT_REWRITE_BASE_URL=https://api.openai.com/v1
PROMPT_REWRITE_MODEL=gpt-4o-mini
PROMPT_REWRITE_TIMEOUT=30
PROMPT_REWRITE_MAX_CHARS=1200
PROMPT_REWRITE_FALLBACK_ON_ERROR=1
